{
  "name": "ai-qa-agent",
  "version": "1.0.0",
  "description": "Gemini API + Playwright AI QA Agent for form testing",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "ai:test": "node runner/runTests.js",
    "ai:test:headed": "cross-env HEADED=true node runner/runTests.js",
    "test": "playwright test --config=playwright.config.js",
    "test:headed": "playwright test --config=playwright.config.js --headed",
    "report": "playwright show-report reports/playwright-report"
  },
  "dependencies": {
    "@google/genai": "latest",
    "dotenv": "latest",
    "express": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "cross-env": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
 